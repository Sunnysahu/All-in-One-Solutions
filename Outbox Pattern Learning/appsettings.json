{
  "ConnectionStrings": {
    "DefaultConnection": "Server=localhost;Database=OutboxPatternDb;Trusted_Connection=True;TrustServerCertificate=True;MultipleActiveResultSets=True"
  },

  "RabbitMq": {
    "HostName": "localhost",
    "Port": 5672,
    "UserName": "guest",
    "Password": "guest",
    "VirtualHost": "/",

    "ExchangeName": "application.events",
    "ExchangeType": "topic",

    "QueueName": "order-processing",
    "RoutingKey": "orders.created",

    "EnablePublisherConfirms": true,
    "AutomaticRecoveryEnabled": true,
    "NetworkRecoveryIntervalSeconds": 10,
    "RequestedHeartbeatSeconds": 60,
    "PrefetchCount": 20
  },

  "Outbox": {
    "BatchSize": 100,
    "PollingIntervalSeconds": 5,

    "MaximumRetryCount": 8,

    "LockDurationSeconds": 60,
    "LockExpirationSeconds": 60,

    "EnableLockRecovery": true,

    "DeadLetterEnabled": true,

    "EnableExponentialBackoff": true,

    "EnableLogging": true,

    "MaxFetchSize": 500
  },

  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.EntityFrameworkCore": "Warning",
      "Microsoft.Hosting.Lifetime": "Information",
      "RabbitMQ.Client": "Warning"
    }
  },

  "AllowedHosts": "*"
}